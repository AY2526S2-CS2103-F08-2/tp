@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":TeamEditCommandParser" as TeamEditCommandParser LOGIC_COLOR
participant "te:TeamEditCommand" as TeamEditCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
participant "ab:AddressBook" as AddressBook MODEL_COLOR
end box

[-> LogicManager : execute("teamedit old/First Team new/Reserve Team")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("teamedit ...")
activate AddressBookParser

create TeamEditCommandParser
AddressBookParser -> TeamEditCommandParser
activate TeamEditCommandParser

TeamEditCommandParser --> AddressBookParser
deactivate TeamEditCommandParser

AddressBookParser -> TeamEditCommandParser : parse(" old/First Team new/Reserve Team")
activate TeamEditCommandParser

create TeamEditCommand
TeamEditCommandParser -> TeamEditCommand
activate TeamEditCommand

TeamEditCommand --> TeamEditCommandParser
deactivate TeamEditCommand

TeamEditCommandParser --> AddressBookParser : te
deactivate TeamEditCommandParser
TeamEditCommandParser -[hidden]-> AddressBookParser
destroy TeamEditCommandParser

AddressBookParser --> LogicManager : te
deactivate AddressBookParser

LogicManager -> TeamEditCommand : execute(m)
activate TeamEditCommand

TeamEditCommand -> Model : hasTeam(oldTeam)
activate Model
Model --> TeamEditCommand
deactivate Model

TeamEditCommand -> Model : setTeam(oldTeam, newTeam)
activate Model
Model -> AddressBook : setTeam(oldTeam, newTeam)
activate AddressBook
AddressBook --> Model
deactivate AddressBook

Model -> Model : cascade rename to assigned persons
Model --> TeamEditCommand
deactivate Model

create CommandResult
TeamEditCommand -> CommandResult
activate CommandResult
CommandResult --> TeamEditCommand
deactivate CommandResult

TeamEditCommand --> LogicManager : r
deactivate TeamEditCommand

[<-- LogicManager
deactivate LogicManager

note over TeamEditCommand
Protected-default and duplicate-destination
validation are omitted for brevity.
end note

note over Model
The same parser-command-model pattern applies
to statusedit and positionedit.
end note
@enduml
