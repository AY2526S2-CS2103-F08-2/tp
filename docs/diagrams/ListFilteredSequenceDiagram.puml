@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":ListCommandParser" as ListCommandParser LOGIC_COLOR
participant "lf:ListFilteredCommand" as ListFilteredCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("list r/player st/Active pos/Defender")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("list r/player st/Active pos/Defender")
activate AddressBookParser

create ListCommandParser
AddressBookParser -> ListCommandParser
activate ListCommandParser

ListCommandParser --> AddressBookParser
deactivate ListCommandParser

AddressBookParser -> ListCommandParser : parse(" r/player st/Active pos/Defender")
activate ListCommandParser

create ListFilteredCommand
ListCommandParser -> ListFilteredCommand
activate ListFilteredCommand

ListFilteredCommand --> ListCommandParser
deactivate ListFilteredCommand

ListCommandParser --> AddressBookParser : lf
deactivate ListCommandParser
ListCommandParser -[hidden]-> AddressBookParser
destroy ListCommandParser

AddressBookParser --> LogicManager : lf
deactivate AddressBookParser

LogicManager -> ListFilteredCommand : execute(m)
activate ListFilteredCommand

ListFilteredCommand -> Model : updateFilteredPersonList(compositePredicate)
activate Model
Model --> ListFilteredCommand
deactivate Model

create CommandResult
ListFilteredCommand -> CommandResult
activate CommandResult
CommandResult --> ListFilteredCommand
deactivate CommandResult

ListFilteredCommand --> LogicManager : r
deactivate ListFilteredCommand

[<--LogicManager
deactivate LogicManager
@enduml
