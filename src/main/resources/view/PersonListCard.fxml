<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Separator?>
<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
        <FlowPane fx:id="staff" alignment="CENTER_LEFT" hgap="4" vgap="2">
          <padding>
           <Insets left="7"/>
          </padding>
        </FlowPane>
      </HBox>
      <FlowPane fx:id="tags" />
      <Label fx:id="team" styleClass="cell_small_label" />
      <Label fx:id="position" styleClass="cell_small_label" />
      <Label fx:id="status" styleClass="cell_small_label" />
      <Separator fx:id="statsSeparatorTop" styleClass="stats-separator" managed="false" visible="false" />
      <VBox fx:id="statsBox" managed="false" visible="false">
      </VBox>
      <Separator fx:id="statsSeparatorBottom" styleClass="stats-separator" managed="false" visible="false" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email" />
    </VBox>
  </GridPane>
</HBox>
